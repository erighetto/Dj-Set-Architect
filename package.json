{
  "name": "dj-set-architect",
  "version": "0.1.0",
  "description": "Local-first Electron app for planning DJ set drafts.",
  "license": "MIT",
  "type": "module",
  "main": "dist/main/main/app/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "dev:electron": "npm run build:main && node scripts/run-electron-dev.cjs",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json && node scripts/write-main-package.cjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run --root .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^11.8.1",
    "electron": "^35.0.0",
    "essentia.js": "^0.1.3",
    "ffmpeg-static": "^5.3.0",
    "plist": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/plist": "^3.0.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.2"
  }
}
